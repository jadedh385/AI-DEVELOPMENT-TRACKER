#!/bin/sh
# AI Landscape Signal — pre-commit gate. Blocks a commit unless the code
# typechecks, lints, and all tests pass. Enable with:
#   git config core.hooksPath .githooks
set -e
echo "▶ pre-commit: typecheck"
npm run --silent typecheck
echo "▶ pre-commit: lint"
npm run --silent lint
echo "▶ pre-commit: tests"
npm run --silent test:run
echo "✓ pre-commit checks passed"
